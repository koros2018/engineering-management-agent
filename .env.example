# ── EMA 环境变量配置模板 ─────────────────────────────────────
# 复制为 .env 并填入实际值:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# 运行环境: development | production
EMA_ENV=production

# API端口
EMA_PORT=6188

# ── 大模型配置 ──────────────────────────────────────────────

# Ollama本地模型服务地址（Docker内访问宿主机用 host.docker.internal）
OLLAMA_HOST=http://host.docker.internal:11434

# 云端大模型 API Key（可选，留空则只用本地Ollama）
# LongCat: https://api.longcat.chat — 获取 API Key
LONGCAT_API_KEY=
# Kimi via OpenCode: https://opencode.ai — 获取 API Key
KIMI_API_KEY=

# ── 安全配置 ────────────────────────────────────────────────

# JWT密钥（生产环境必须修改！用 openssl rand -hex 32 生成）
JWT_SECRET=change-me-in-production-please

# ── 微信小程序（可选）────────────────────────────────────────
WECHAT_APPID=
WECHAT_SECRET=
WECHAT_MODE=mock  # mock=模拟模式(演示用) | real=真实微信对接

# ── 邮箱通知（可选）──────────────────────────────────────────
SMTP_HOST=smtp.qq.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ── 资源限制 ────────────────────────────────────────────────
EMA_MEMORY_LIMIT=2G
EMA_CPU_LIMIT=2.0

# ── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=INFO  # DEBUG | INFO | WARNING | ERROR

# ── 数据 ────────────────────────────────────────────────────
EMA_DATA_PATH=./data
