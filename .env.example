# ── EMA 环境变量配置模板 ─────────────────────────────────────
# 复制为 .env 并填入实际值:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# 运行环境: development | production
EMA_ENV=production

# API端口
EMA_PORT=6188

# Ollama本地模型服务地址（宿主机访问用 host.docker.internal）
OLLAMA_HOST=http://host.docker.internal:11434

# NVIDIA API Key（用于云端大模型，可选）
NVIDIA_API_KEY=

# JWT密钥（生产环境必须修改！）
JWT_SECRET=change-me-in-production-please

# 资源限制
EMA_MEMORY_LIMIT=2G
EMA_CPU_LIMIT=2.0

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 数据持久化路径（宿主机）
EMA_DATA_PATH=./data
