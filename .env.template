# EMA 生产环境配置
# 复制此文件为 .env 并填写真实值

# ── 应用 ────────────────────────────────────────────────────
EMA_ENV=production
EMA_HOST=0.0.0.0
EMA_PORT=6188

# ── JWT ────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-to-a-secure-random-string-64-chars
JWT_ALGORITHM=RS256
# 生产环境建议使用 RS256:
# JWT_PRIVATE_KEY_PATH=/path/to/private.pem
# JWT_PUBLIC_KEY_PATH=/path/to/public.pem

# ── Ollama ──────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_CLOUD_API=https://api.ollama.com/v1/chat/completions
OLLAMA_CLOUD_KEY=your-api-key-here

# ── 微信支付 V3 ────────────────────────────────────────────
# 公众号/小程序 AppID
WECHAT_APP_ID=wx_your_app_id
# 商户号
WECHAT_MCH_ID=your_mch_id
# API v3 密钥（32位）
WECHAT_API_V3_KEY=your-32-char-api-v3-key
# 商户私钥路径（PEM格式）
WECHAT_PRIVATE_KEY_PATH=/path/to/apiclient_key.pem
# 证书序列号
WECHAT_CERT_SERIAL_NO=your_cert_serial
# 回调地址
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/payment/wechat-callback

# ── 支付宝 ──────────────────────────────────────────────────
ALIPAY_APP_ID=your_alipay_app_id
# 应用私钥
ALIPAY_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
...
-----END RSA PRIVATE KEY-----
# 支付宝公钥
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
...
-----END PUBLIC KEY-----
# 网关
ALIPAY_GATEWAY=https://openapi.alipay.com/gateway.do
# 回调地址
ALIPAY_NOTIFY_URL=https://your-domain.com/api/v1/payment/alipay-callback

# ── 数据库 ──────────────────────────────────────────────────
# 生产环境建议切换到 PostgreSQL
# DATABASE_URL=postgresql://user:pass@localhost:5432/ema

# ── 安全 ────────────────────────────────────────────────────
# CORS 白名单（逗号分隔）
CORS_ORIGINS=http://localhost,https://your-domain.com
# 速率限制
RATE_LIMIT_RPS=20
RATE_LIMIT_BLOCK_THRESHOLD=50
# 文件限制
MAX_UPLOAD_MB=500

# ── 日志 ────────────────────────────────────────────────────
LOG_LEVEL=info
LOG_FILE=logs/ema.log

# ── Blueprint-AI（如需独立部署）───────────────────────────
# BLUEPRINT_AI_URL=http://127.0.0.1:6188
